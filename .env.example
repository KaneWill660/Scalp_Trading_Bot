# ── MT5 ──────────────────────────────────────────────
MT5_LOGIN=
MT5_PASSWORD=
MT5_SERVER=

# ── Telegram ─────────────────────────────────────────
TELEGRAM_BOT_TOKEN=your_token_here
TELEGRAM_CHAT_ID=

# ── Symbols (phân cách bằng dấu phẩy) ────────────────
SYMBOLS=XAUUSDc,EURUSDc,GBPUSDc,BTCUSDc

# ── Risk ─────────────────────────────────────────────
# Risk % mỗi lệnh (0.01 = 1% balance)
RISK_PERCENT=0.01
# Lot cố định per-symbol (bỏ comment để override risk %)
#SYMBOL_LOT_XAUUSDc=0.02
#SYMBOL_LOT_EURUSDc=0.05
LEVERAGE=100
# Lỗ tối đa cho 1 lệnh (USD). 0 = tắt. Lệnh có SL rộng khiến lỗ dự kiến > số này sẽ bị bỏ.
#MAX_LOSS_PER_TRADE=0

# ── Strategy (tùy chọn — mặc định như dưới) ──────────
# Chiến lược: ema_pullback | price_action
#STRATEGY=ema_pullback
# Khung entry: M5 | M15 | M30
#ENTRY_TF=M5
#EMA_TREND_FAST=50
#EMA_TREND_SLOW=200
#EMA_PULLBACK_FAST=20
#EMA_PULLBACK_SLOW=50
#ATR_PERIOD=14
#SL_ATR_MULT=1.5
#RR=2.0
#MAX_SL_ATR_H1_MULT=1.0
# Lọc chất lượng trend H1 (0 = tắt)
#MIN_ADX_H1=25
#MIN_EMA_GAP_ATR=1.0
#ADX_PERIOD=14
# Loại nến xác nhận (engulfing,pinbar hoặc chỉ 1 loại)
#CANDLE_TYPES=engulfing,pinbar

# ── Chiến lược price_action (khi STRATEGY=price_action) ──
# Setup bật (backtest XAU M30 12mo: flag/engulfing/triangle/hammer dương;
# harami/double_hammer âm; double_doji gần như không có lệnh)
#PATTERNS=flag,engulfing,triangle,hammer
#ZONE_LOOKBACK=150
#ZONE_SWING_N=3
#IMPULSE_ATR_MULT=2.0
#ZONE_ATR_MULT=0.5
#ZONE_SL_BUFFER_ATR=0.25
#MIN_BASE_BARS=2
#CONFIRM_WINDOW_BARS=3
#DOJI_BODY_RATIO=0.15
#FLAG_POLE_BARS=10
#FLAG_POLE_ATR=3.0
#FLAG_MIN_BARS=4
#FLAG_MAX_BARS=15
#TRIANGLE_WINDOW=30
#TRIANGLE_COMPRESS=0.6

# ── Session (giờ UTC) ────────────────────────────────
# 0 = trade 24/7 không giới hạn phiên; 1 = chỉ London/NY (mặc định)
SESSION_FILTER=1
#SESSION_START=07:00
#SESSION_END=15:30
# Chênh lệch giờ server MT5 so với UTC — dùng cho session filter khi backtest.
# Kiểm tra: so giờ trong Market Watch của MT5 với giờ UTC hiện tại.
#SERVER_UTC_OFFSET_HOURS=0
